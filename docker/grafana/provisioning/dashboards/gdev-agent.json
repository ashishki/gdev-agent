{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (tenant_hash,status) (rate(gdev_requests_total[5m]))",
          "legendFormat": "{{tenant_hash}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le,tenant_hash) (rate(gdev_llm_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tenant_hash}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le,tenant_hash) (rate(gdev_llm_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tenant_hash}}",
          "refId": "B"
        }
      ],
      "title": "LLM Latency p50/p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (tenant_hash) (increase(gdev_llm_cost_usd_total[1d]))",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "LLM Cost USD (Cumulative)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "max by (tenant_hash) (gdev_budget_utilization_ratio)",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "Budget Utilization Ratio",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (guard_type,tenant_hash) (rate(gdev_guard_blocks_total[5m]))",
          "legendFormat": "{{tenant_hash}} {{guard_type}}",
          "refId": "A"
        }
      ],
      "title": "Guard Block Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 6,
      "targets": [
        {
          "expr": "max by (tenant_hash) (gdev_approval_queue_depth)",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "Pending Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "id": 8,
      "targets": [
        {
          "expr": "max by (tenant_hash) (gdev_rca_clusters_active)",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "Active RCA Clusters",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(gdev_llm_requests_total{status=\"error\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 32
      },
      "id": 12,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le,tenant_hash) (rate(gdev_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tenant_hash}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le,tenant_hash) (rate(gdev_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tenant_hash}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le,tenant_hash) (rate(gdev_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tenant_hash}}",
          "refId": "C"
        }
      ],
      "title": "Webhook Request Latency p50/p95/p99",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 32
      },
      "id": 13,
      "targets": [
        {
          "expr": "sum by (tenant_hash) (increase(gdev_pending_total[1h]))",
          "legendFormat": "pending {{tenant_hash}}",
          "refId": "A"
        },
        {
          "expr": "sum by (tenant_hash) (increase(gdev_approved_total[1h]))",
          "legendFormat": "approved {{tenant_hash}}",
          "refId": "B"
        },
        {
          "expr": "sum by (tenant_hash) (increase(gdev_rejected_total[1h]))",
          "legendFormat": "rejected {{tenant_hash}}",
          "refId": "C"
        }
      ],
      "title": "Approval Workflow Outcomes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 32
      },
      "id": 14,
      "targets": [
        {
          "expr": "sum by (tenant_hash) (increase(gdev_budget_exceeded_total[1h]))",
          "legendFormat": "budget {{tenant_hash}}",
          "refId": "A"
        },
        {
          "expr": "sum by (tenant_hash) (increase(gdev_llm_retry_total[1h]))",
          "legendFormat": "llm retry {{tenant_hash}}",
          "refId": "B"
        },
        {
          "expr": "sum by (integration,tenant_hash) (increase(gdev_integration_errors_total[1h]))",
          "legendFormat": "{{integration}} {{tenant_hash}}",
          "refId": "C"
        }
      ],
      "title": "Failure Mode Signals",
      "type": "timeseries"
    }
