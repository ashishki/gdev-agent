{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (tenant_hash,status) (rate(gdev_requests_total[5m]))",
          "legendFormat": "{{tenant_hash}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le,tenant_hash) (rate(gdev_llm_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tenant_hash}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le,tenant_hash) (rate(gdev_llm_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tenant_hash}}",
          "refId": "B"
        }
      ],
      "title": "LLM Latency p50/p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (tenant_hash) (increase(gdev_llm_cost_usd_total[1d]))",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "LLM Cost USD (Cumulative)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "max by (tenant_hash) (gdev_budget_utilization_ratio)",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "Budget Utilization Ratio",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (guard_type,tenant_hash) (rate(gdev_guard_blocks_total[5m]))",
          "legendFormat": "{{tenant_hash}} {{guard_type}}",
          "refId": "A"
        }
      ],
      "title": "Guard Block Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 6,
      "targets": [
        {
          "expr": "max by (tenant_hash) (gdev_approval_queue_depth)",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "Pending Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT NOW() AS time, tenant_id::text AS tenant_hash, COALESCE(ROUND((COUNT(*) FILTER (WHERE override_kind IS NOT NULL))::numeric / NULLIF(COUNT(*), 0), 3), 0)::float AS override_rate, COALESCE(ROUND((COUNT(*) FILTER (WHERE decision = 'rejected'))::numeric / NULLIF(COUNT(*), 0), 3), 0)::float AS rejection_rate, COUNT(*) AS reviewed_count FROM approval_events WHERE created_at > NOW() - INTERVAL '1 day' GROUP BY tenant_id",
          "refId": "A"
        }
      ],
      "title": "Override/Rejection Rate (24h)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "id": 8,
      "targets": [
        {
          "expr": "max by (tenant_hash) (gdev_rca_clusters_active)",
          "legendFormat": "{{tenant_hash}}",
          "refId": "A"
        }
      ],
      "title": "Active RCA Clusters",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(gdev_llm_requests_total{status=\"error\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "id": 10,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT NOW() AS time, tenant_id::text AS tenant_hash, ROUND((percentile_cont(0.5) WITHIN GROUP (ORDER BY latency_ms))::numeric)::integer AS p50_ms, ROUND((percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms))::numeric)::integer AS p95_ms FROM approval_events WHERE created_at > NOW() - INTERVAL '1 day' AND latency_ms IS NOT NULL GROUP BY tenant_id",
          "refId": "A"
        }
      ],
      "title": "Approval Latency p50/p95 (24h)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "id": 11,
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, tenant_id::text AS tenant_hash, COUNT(*) AS reviewed_count FROM approval_events WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Reviewed Approval Volume",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "gdev-agent",
    "phase5"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "title": "gdev-agent Observability",
  "uid": "gdev-agent",
  "version": 1
}
